<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/bgImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/home"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageButton
                    android:id="@+id/menuButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Menü"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@android:color/white" />

                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/headerTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Könyv módosítása"
                            android:textColor="#1E1E1E"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/adminText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Admin:"
                            android:textColor="#444444"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Könyv címe:"
                            android:textColor="#1E1E1E"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/titleEntry"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/edittext_rounded"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="#1E1E1E"
                            android:textColorHint="#8A8A8A" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Szerző:"
                            android:textColor="#1E1E1E"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/authorEntry"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/edittext_rounded"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="#1E1E1E"
                            android:textColorHint="#8A8A8A" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Kategória:"
                            android:textColor="#1E1E1E"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/categoryEntry"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/edittext_rounded"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="#1E1E1E"
                            android:textColorHint="#8A8A8A" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Kiadás dátuma:"
                            android:textColor="#1E1E1E"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/releaseEntry"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/edittext_rounded"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="#1E1E1E"
                            android:textColorHint="#8A8A8A" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Leírás:"
                            android:textColor="#1E1E1E"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/descriptionEntry"
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/edittext_rounded"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:padding="14dp"
                            android:textColor="#1E1E1E"
                            android:textColorHint="#8A8A8A" />

                        <ImageView
                            android:id="@+id/imagePreview"
                            android:layout_width="180dp"
                            android:layout_height="240dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="10dp"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop"
                            android:src="@drawable/book_placeholder" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Borító módosítása:"
                            android:textColor="#1E1E1E"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/selectImageButton"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:backgroundTint="#5A8DF0"
                            android:text="Kép kiválasztása"
                            android:textColor="@android:color/white" />

                        <Button
                            android:id="@+id/saveImageButton"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:backgroundTint="#5A8DF0"
                            android:text="Mentés könyvtárba"
                            android:textColor="@android:color/white" />

                        <TextView
                            android:id="@+id/imageLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Jelenlegi kép:"
                            android:textColor="#555555"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/submitButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="24dp"
                            android:backgroundTint="#5CB85C"
                            android:text="Módosítás mentése"
                            android:textColor="@android:color/white" />

                        <Button
                            android:id="@+id/backButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="#5A8DF0"
                            android:text="Vissza"
                            android:textColor="@android:color/white" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#F2F2F2"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Menü"
            android:textColor="#1E1E1E"
            android:textSize="24sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/profileButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/glass_button_blue"
            android:text="Profilom"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/communityButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/glass_button_blue"
            android:text="Közösség"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/eventsButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/glass_button_blue"
            android:text="Események"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/logoutButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/glass_button_red"
            android:text="Kijelentkezés"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>